{
  "name": "juno-voice-relay",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Juno realtime voice relay — one client WebSocket, provider sessions server-side (OpenAI Realtime, Gemini Live, Qwen Omni Realtime, MiniMax composed).",
