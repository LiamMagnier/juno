      "isCommentAutoGenerated": true
    },
    "Instructions": {},
    "Juno": {
      "comment": "The name of the app.",
      "isCommentAutoGenerated": true
    },
    "Juno remembers helpful details from your chats so it can give you better, more personalized answers.": {
      "comment": "A description of how Juno remembers user input.",
      "isCommentAutoGenerated": true
    },
    "Juno will no longer use this fact in conversations.": {
      "comment": "A confirmation alert that warns the user that erasing a memory will remove it from the app.",
      "isCommentAutoGenerated": true
    },
    "Light": {},
    "Linked conversations are kept. Project files are removed.": {
      "comment": "(",
