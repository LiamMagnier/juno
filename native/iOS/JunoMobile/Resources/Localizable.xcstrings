    },
    "No summary yet — Juno builds this from what it learns in chats.": {
      "comment": "A description of the user's memory if it's empty.",
      "isCommentAutoGenerated": true
    },
    "Nothing matches “%@”.": {
      "comment": "A description of the search results when there are no results for the current search query. The argument is the search query.",
