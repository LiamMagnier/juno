      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your local data stays on this device and syncs again when you sign back in."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos données locales restent sur cet appareil et se resynchronisent à la reconnexion."
          }
        }
      }
    },
    "auth.sign-out.confirm.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign out of Juno?"
