{
  "name": "juno",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "i18n:extract": "node scripts/generate-i18n-catalog.mjs",
    "predev": "npm run i18n:extract",
    "dev": "next dev",
    "prebuild": "npm run i18n:extract",
    "build": "prisma generate && NODE_OPTIONS=--max-old-space-size=2048 next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test:memory": "NODE_OPTIONS=--conditions=react-server tsx scripts/test-memory.ts",
    "test:auth": "tsx scripts/test-auth.ts",
    "test:clarify": "NODE_OPTIONS=--conditions=react-server tsx scripts/test-clarify.ts",
    "test:moderation": "NODE_OPTIONS=--conditions=react-server tsx scripts/test-moderation.ts",
    "crypto:rotate": "NODE_OPTIONS=--conditions=react-server tsx scripts/rotate-encryption-keys.ts",
    "tasks:runner": "NODE_OPTIONS=--conditions=react-server tsx scripts/scheduled-task-runner.ts",
    "validate:models": "tsx scripts/validate-models.ts",
    "sync:models": "tsx scripts/sync-models.ts",
    "sync:models:write": "tsx scripts/sync-models.ts --write --prune",
    "sync:benchmarks": "tsx scripts/fetch-benchmarks.ts",
    "radar:models": "tsx scripts/model-radar.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@composio/core": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-visually-hidden": "^1.2.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "highlight.js": "^11.11.1",
    "imapflow": "^1.4.3",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.22.0",
    "next": "^15.5.0",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.0",
    "openai": "^6.45.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/imapflow": "^1.0.23",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
