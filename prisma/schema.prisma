// Juno — Prisma schema (PostgreSQL)
// Run `npx prisma migrate dev` (local) or `npx prisma migrate deploy` (prod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Auth (NextAuth / Auth.js with Prisma adapter + JWT sessions)
// ----------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String? // null for OAuth-only users
  // Incremented after a password reset. JWTs carry the version they were
  // issued with, so every older session becomes invalid immediately.
  sessionVersion Int       @default(0)

  // Moderation: a set bannedAt means the account is suspended (sign-in blocked,
  // active sessions killed). strikes accumulates soft violations toward auto-ban.
  bannedAt  DateTime?
  banReason String?
  bannedBy  String? // admin email, or "system" for automatic bans
  strikes   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  settings                 Settings?
  subscription             Subscription?
  folders                  Folder[]
  conversations            Conversation[]
  memories                 MemoryEntry[]
  memorySummary            MemorySummary?
  conversationMemories     ConversationMemory[]
  attachments              Attachment[]
  usage                    Usage[]
  featureRequests          FeatureRequest[]
  votes                    FeatureVote[]
  featureComments          FeatureComment[]
  projects                 Project[]
  savedPrompts             SavedPrompt[]
  authoredAnnouncements    Announcement[]            @relation("AnnouncementAuthor")
  announcementDismissals   AnnouncementDismissal[]
  connections              Connection[]
  codeDevices              CodeDevice[]
  codeTasks                CodeTask[]
  apiSpend                 ApiSpend[]
  moderationFlags          ModerationFlag[]
  shares                   Share[]
  scheduledTasks           ScheduledTask[]
  voiceTranscriptSessions  VoiceTranscriptSession[]
  nativeAuthorizationCodes NativeAuthorizationCode[]
  nativeDeviceSessions     NativeDeviceSession[]
  accountChanges           AccountChange[]
  entityRevisions          EntityRevision[]
  mutationReceipts         MutationReceipt[]
  codeWorkspaces           CodeWorkspace[]
  chatFirstSubmissionReceipts ChatFirstSubmissionReceipt[]
}

// ----------------------------------------------------------------------------
// External tool connectors (GitHub, Figma, …) linked via OAuth. Tokens are
// stored encrypted at rest and exposed to the model as MCP tools.
// ----------------------------------------------------------------------------

model Connection {
  id                String    @id @default(cuid())
  userId            String
  provider          String // connector id: "github" | "figma" | "notion"
  accessToken       String    @db.Text // encrypted (AES-256-GCM)
  refreshToken      String?   @db.Text // encrypted
  oauthClientId     String? // mcp_oauth: the dynamically-registered client (RFC 7591)
  oauthClientSecret String?   @db.Text // encrypted; only if the MCP server issues a confidential client
  scope             String?
  accountLabel      String? // human label: GitHub login / Figma handle
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Native clients authenticate with short-lived access tokens and rotating
// refresh tokens. Raw Auth.js cookies must never cross the browser boundary.
model NativeAuthorizationCode {
  id                 String    @id @default(cuid())
  codeHash           String    @unique
  userId             String
  codeChallenge      String
  redirectUri        String
  nonce              String
  installationIdHash String
  createdAt          DateTime  @default(now())
  expiresAt          DateTime
  usedAt             DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model NativeDeviceSession {
  id                 String    @id @default(cuid())
  userId             String
  installationIdHash String
  name               String
  platform           String
  appVersion         String
  createdAt          DateTime  @default(now())
  lastSeenAt         DateTime  @default(now())
  revokedAt          DateTime?
  revocationReason   String?

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens NativeRefreshToken[]

  @@index([userId, revokedAt])
  @@index([userId, installationIdHash])
}

model NativeRefreshToken {
  id              String    @id @default(cuid())
  deviceSessionId String
  familyId        String
  tokenHash       String    @unique
  parentTokenId   String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?

  deviceSession NativeDeviceSession @relation(fields: [deviceSessionId], references: [id], onDelete: Cascade)

  @@index([deviceSessionId, familyId])
  @@index([expiresAt])
}

model AccountChange {
  cursor         BigInt   @id @default(autoincrement())
  accountId      String
  entityType     String
  entityId       String
  parentEntityId String?
  revision       Int
  operation      String
  changedAt      DateTime @default(now())

  account User @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, cursor])
}

model EntityRevision {
  id             String    @id @default(cuid())
  accountId      String
  entityType     String
  entityId       String
  parentEntityId String?
  revision       Int       @default(1)
  deletedAt      DateTime?
  updatedAt      DateTime  @updatedAt

  account User @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, entityType, entityId])
  @@index([accountId, entityType])
}

/// Change-log compaction state — a single "global" row recording the highest
/// AccountChange cursor the retention pruner has deleted. bootstrap/changes
/// serve it as compactionFloorCursor; a client whose cursor predates it may
/// have missed pruned changes and must resync from bootstrap (410).
model SyncCompaction {
  id          String   @id
  floorCursor BigInt   @default(0)
  prunedAt    DateTime @default(now())
}

model MutationReceipt {
  id                    String   @id @default(cuid())
  accountId             String
  authenticatedDeviceId String
  clientMutationId      String
  requestHash           String
  status                Int
  result                Json
  createdAt             DateTime @default(now())

  account User @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, authenticatedDeviceId, clientMutationId])
  @@index([accountId, createdAt])
}

// ----------------------------------------------------------------------------
// Settings / profile preferences
// ----------------------------------------------------------------------------

/// Prompt library — reusable prompts the user saves and re-runs from the
/// composer's "/" menu. Body is stored plaintext on purpose: these are the
/// user's own templates, not conversation content, and they must be searchable.
model SavedPrompt {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  /// Times the user has inserted it — drives most-used ordering.
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model Settings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  theme              Theme    @default(SYSTEM)
  accent             String   @default("coral")
  defaultModel       String   @default("claude-sonnet-4-6")
  customInstructions String   @default("") @db.Text
  responseLanguage   String   @default("auto")
  // Interface language: "auto" (follow Accept-Language) or a BCP-47 tag.
  // Distinct from responseLanguage, which is the AI's reply language and holds
  // English language NAMES ("French"), not tags.
  uiLocale           String   @default("auto")
  // Response personality. A preset id from lib/personalities.ts ("default",
  // "concise", "socratic"…). Layered UNDER customInstructions so a user's own
  // instructions always win.
  personality        String   @default("default")
  memoryEnabled      Boolean  @default(true)
  voiceId            String? // preferred TTS voice id
  favoriteModels     String[] @default([]) // model ids the user starred
  // Lifecycle email opt-ins — no-ops until RESEND_API_KEY is configured.
  emailBudgetAlerts  Boolean  @default(true) // ~80% plan-budget warning
  emailWeeklyDigest  Boolean  @default(false) // weekly usage recap
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Conversations & messages
// ----------------------------------------------------------------------------

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([userId])
}

model Conversation {
  id               String    @id @default(cuid())
  userId           String
  // Durable creation surface. NULL means the conversation predates precise
  // origin metadata or arrived through a legacy caller that only sent web|app.
  origin           String?
  // Idempotency key for creation + the first saved Quick/native submission.
  // Scoped to the account so retries cannot create parallel conversations.
  clientRequestId  String?
  title            String    @default("New chat")
  titleSource      String    @default("default")
  model            String    @default("claude-opus-4-8")
  // Which surface owns this conversation: "chat" (web + app chat) or "code"
  // (Juno Code sessions synced from the app).
  kind             String    @default("chat")
  // For kind "code": the app-side workspace (project folder) the session
  // belongs to, so the website can group sessions the way the app does.
  // codeWorkspaceKey is the stable identity (CodeWorkspace.key) when known;
  // name/path are display + device metadata that can change without forking
  // the session's workspace attribution.
  codeWorkspaceName String?
  codeWorkspacePath String?
  codeWorkspaceKey  String?
  pinned           Boolean   @default(false)
  // Archived chats stay fully readable and searchable but leave the sidebar's
  // Recent list. Nullable timestamp rather than a boolean so "when" is kept.
  archivedAt       DateTime?
  folderId         String?
  projectId        String?
  // Branch-from-here: the conversation this one was forked from (plain pointer,
  // not a relation — the source may be deleted independently).
  forkedFromId     String?
  // Tool connectors (github/figma/notion…) the user turned on for this chat.
  // Persisted so they stay active for every later prompt without re-toggling.
  activeConnectors String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastMessageAt    DateTime  @default(now())

  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder                  Folder?                  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  project                 Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages                Message[]
  attachments             Attachment[]
  artifacts               Artifact[]
  memory                  ConversationMemory?
  shares                  Share[]
  voiceTranscriptSessions VoiceTranscriptSession[]

  @@index([userId, lastMessageAt])
  @@index([userId, pinned])
  @@index([projectId])
  @@unique([userId, clientRequestId])
}

model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String   @default("Untitled project")
  nameSource   String   @default("default")
  instructions String   @default("") @db.Text
  // Starred projects surface in the sidebar's Pinned section. Server-side so
  // stars follow the account across devices (was localStorage-only).
  starred      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  files         Attachment[]

  @@index([userId, updatedAt])
}

model Message {
  id               String    @id @default(cuid())
  conversationId   String
  // Client-generated idempotency key for native transcript pushes
  // (POST /api/conversations/[id]/messages). Unique per conversation, so a
  // retried batch can never duplicate a turn. NULL for every message written
  // by the web pipeline, which has no client-side retry surface.
  clientId         String?
  role             Role
  content          String    @db.Text
  reasoning        String?   @db.Text // visible chain-of-thought when a thinking model is used
  // The same thinking kept as the discrete parts the provider actually emitted:
  // an array of encrypted strings, one per part, in order (encrypted exactly
  // like `reasoning`, same message-crypto path). Written only by providers that
  // deliver parts on the wire — NULL means the provider streamed unbroken prose
  // and no step structure ever existed. Nullable and additive, so every message
  // written before this column degrades to "reasoning, no steps" on its own.
  reasoningParts   Json? // [encrypted part, …] — discrete reasoning summary parts
  model            String?
  feedback         Feedback? // thumbs up/down on assistant messages
  promptTokens     Int?
  completionTokens Int?
  // Exact generation cost at write time (tokens + cache + tool fees), micro-USD.
  // Serializer prefers this over recomputing from token counts alone (which
  // drop cache writes and web-search fees and under-report badly).
  costMicroUsd     Int?
  sources          Json? // web-search citations: [{ title, url, snippet }]
  activity         Json? // visible generation timeline: [{ id, kind, title, detail?, url?, createdAt }]
  createdAt        DateTime  @default(now())

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]
  artifacts    Artifact[]
  versions     MessageVersion[]

  @@unique([conversationId, clientId])
  @@index([conversationId, createdAt])
}

// Durable idempotency receipt for the first saved native/Quick submission.
// The request hash binds every generation-affecting client field to one
// canonical server generation id. State is a string (rather than a PostgreSQL
// enum) so future receipt states remain an additive deployment.
model ChatFirstSubmissionReceipt {
  id                String    @id @default(cuid())
  userId            String
  clientRequestId   String
  clientMessageId   String
  requestHash       String
  generationId      String    @unique
  state             String    @default("accepted") // claimed | accepted | running | completed | failed
  conversationId    String
  userMessageId     String
  assistantMessageId String?
  finishReason      String?
  failureCode       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?
  leaseExpiresAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientRequestId])
  @@unique([userId, clientMessageId])
  @@index([conversationId])
}

// Idempotency ledger for saving a realtime voice session. A browser may retry
// on relay close/navigation; the same session must never duplicate messages.
model VoiceTranscriptSession {
  userId         String
  sessionId      String
  conversationId String
  messageIds     String[] @default([])
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, sessionId])
  @@index([conversationId])
}

model Attachment {
  id             String         @id @default(cuid())
  userId         String
  conversationId String?
  messageId      String?
  kind           AttachmentKind
  fileName       String
  mimeType       String
  size           Int
  storageKey     String // object key in the bucket
  extractedText  String?        @db.Text // text content extracted from documents
  width          Int?
  height         Int?
  createdAt      DateTime       @default(now())

  projectId String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
  @@index([projectId])
}

// ----------------------------------------------------------------------------
// Memory
// ----------------------------------------------------------------------------

model MemoryEntry {
  id        String       @id @default(cuid())
  userId    String
  content   String       @db.Text
  source    MemorySource @default(AUTO)
  // FACT = remembered content · SUPPRESSION = "never remember this" (highest-
  // priority layer: filters candidate ingestion AND the consolidated summary).
  kind      MemoryKind   @default(FACT)
  // Where this came from: a conversationId, "manual", or "edit".
  sourceRef String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, kind])
}

// Per-conversation extraction state: messages up to `processedAt` have been
// distilled into MemoryEntry facts. Lets every chat contribute exactly once,
// supports incremental updates after new messages, and makes old-chat
// backfill resumable.
model ConversationMemory {
  id             String   @id @default(cuid())
  userId         String
  conversationId String   @unique
  processedAt    DateTime // high-water mark: messages createdAt <= this are extracted
  digest         String?  @db.Text // one-line memory digest of the chat
  factCount      Int      @default(0) // facts extracted from this chat so far
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A periodically-regenerated, deduped summary of the user's memories (markdown,
// organized into sections). Used in context instead of the raw entry list.
model MemorySummary {
  id         String   @id @default(cuid())
  userId     String   @unique
  content    String   @db.Text
  entryCount Int      @default(0) // # of memory entries this summary was built from
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Artifacts (canvas)
// ----------------------------------------------------------------------------

model Artifact {
  id             String       @id @default(cuid())
  conversationId String
  messageId      String?
  identifier     String // stable id used by the model to update an artifact
  title          String
  type           ArtifactType
  language       String? // for code artifacts
  currentVersion Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  versions     ArtifactVersion[]
  shares       Share[]

  @@unique([conversationId, identifier])
  @@index([conversationId])
}

model ArtifactVersion {
  id         String   @id @default(cuid())
  artifactId String
  version    Int
  content    String   @db.Text
  // How this version came to be: "generated" (model output), "edit" (manual
  // user edit), "restore" (user restored an older version). Null on rows
  // written before the column existed — the UI renders those without a badge.
  origin     String?
  createdAt  DateTime @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, version])
}

// ----------------------------------------------------------------------------
// Billing & usage
// ----------------------------------------------------------------------------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 Plan      @default(FREE)
  status               SubStatus @default(ACTIVE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Monthly usage counter for quota enforcement. `period` is "YYYY-MM".
// Token counters aggregate real usage across the web chat and Juno Code so a
// single account view reflects everything drawn against the plan.
model Usage {
  id               String @id @default(cuid())
  userId           String
  period           String
  messageCount     Int    @default(0)
  promptTokens     BigInt @default(0)
  completionTokens BigInt @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
}

// Fixed-window rate limiting (works across serverless instances).
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

// ----------------------------------------------------------------------------
// Product / model release announcements
// ----------------------------------------------------------------------------

model Announcement {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  imageUrl    String?
  videoUrl    String?
  provider    String?
  modelName   String?
  newsLabel   String?
  newsHref    String?
  ctaLabel    String?
  ctaHref     String?
  published   Boolean   @default(false)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy  User                    @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  dismissals AnnouncementDismissal[]

  @@index([published, startsAt])
  @@index([createdAt])
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  dismissedAt    DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([announcementId])
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum MemorySource {
  AUTO
  MANUAL
}

enum MemoryKind {
  FACT
  SUPPRESSION
}

enum AttachmentKind {
  IMAGE
  FILE
}

enum ArtifactType {
  HTML
  REACT
  CODE
  MARKDOWN
  SVG
  MERMAID
}

// ----------------------------------------------------------------------------
// Per-request API cost ledger. One row per billable model call; monthly sums
// drive the plan budget gauge. Never decremented when content is deleted.
// ----------------------------------------------------------------------------

model ApiSpend {
  id               String   @id @default(cuid())
  userId           String
  model            String
  kind             String   @default("chat") // chat | image | video | voice | code
  source           String   @default("web") // web | app — which surface produced the spend
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costMicroUsd     Int // request cost in micro-USD (1e-6 $) — integer math only
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ----------------------------------------------------------------------------
// Moderation flags — one row per detected CGU/policy violation (automatic AI
// moderation or a manual admin note). Soft violations add a strike; severe ones
// ban immediately. Kept for the admin audit trail and appeals.
// ----------------------------------------------------------------------------

model ModerationFlag {
  id             String    @id @default(cuid())
  userId         String
  source         String    @default("auto") // auto | manual
  severity       String    @default("low") // low | medium | high | critical
  category       String    @default("other")
  detail         String    @db.Text
  messagePreview String?   @db.Text // redacted/truncated snippet that triggered it
  action         String    @default("flagged") // flagged | strike | banned
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewedAt])
}

enum Plan {
  FREE
  PRO
  MAX
  MAX20
  OWNER
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum Feedback {
  UP
  DOWN
}

// ---- Feature Requests & Roadmap ----

model FeatureRequest {
  id            String          @id @default(cuid())
  authorId      String
  title         String
  description   String          @db.Text
  category      FeatureCategory @default(OTHER)
  status        FeatureStatus   @default(UNDER_REVIEW)
  pinned        Boolean         @default(false)
  declineReason String?
  mergedIntoId  String? // duplicate handling
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  author   User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes    FeatureVote[]
  comments FeatureComment[]
  events   FeatureStatusEvent[]

  @@index([status, createdAt])
}

model FeatureVote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  createdAt DateTime @default(now())

  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId]) // one vote per user
  @@index([userId])
}

model FeatureComment {
  id        String   @id @default(cuid())
  requestId String
  authorId  String
  body      String   @db.Text
  official  Boolean  @default(false) // OWNER/team reply styling
  createdAt DateTime @default(now())

  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model FeatureStatusEvent {
  id        String        @id @default(cuid())
  requestId String
  status    FeatureStatus
  note      String?
  createdAt DateTime      @default(now())

  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

enum FeatureStatus {
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
}

enum FeatureCategory {
  CHAT
  MODELS
  CANVAS
  MEMORY
  VOICE
  FILES
  BILLING
  UI
  INTEGRATIONS
  OTHER
}

// ----------------------------------------------------------------------------
// Remote code task queue (Mac hosts run coding tasks queued from other clients)
// ----------------------------------------------------------------------------

model CodeDevice {
  id         String   @id @default(cuid())
  userId     String
  name       String
  platform   String   @default("macos")
  workspaces Json     @default("[]")
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks CodeTask[]

  @@unique([userId, name])
}

model CodeTask {
  id            String   @id @default(cuid())
  userId        String
  // Null for cloud tasks (target = "cloud"), which run on a GitHub Actions
  // runner with no registered device. Device tasks still carry their device.
  deviceId      String?
  workspacePath String
  workspaceName String   @default("")
  // Stable workspace identity (CodeWorkspace.key) when the submitting client
  // knows it. Plain string, not a relation — the executing device resolves
  // its own local path, and the workspace row may be re-mirrored freely.
  workspaceKey  String?
  title         String
  prompt        String   @db.Text
  status        String   @default("queued")
  lastSeq       Int      @default(0)
  // The kind:"code" Conversation this task ran in, so the website's code
  // session view can join history/status. Plain pointer, not a relation —
  // the conversation may be deleted independently of the task record.
  conversationId String?
  // Cloud Juno Code (GitHub Actions runner). target: "device" (default) |
  // "cloud". For cloud tasks, repoOwner/repoName/baseRef pin the repo the
  // runner clones + branches from, and prUrl records the PR it opens.
  target        String   @default("device")
  repoOwner     String?
  repoName      String?
  baseRef       String?
  prUrl         String?
  // Cloud runner one-time handoff: set the first time the GitHub Actions runner
  // successfully exchanges its dispatch code for runner-context (clone token +
  // fresh task token). A non-null value means that handoff is spent, so a
  // second runner-context call for this task is refused — the clone token is
  // handed out AT MOST once per task. NULL for device tasks and un-started runs.
  runnerClaimedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  device CodeDevice?     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  events CodeTaskEvent[]

  @@index([userId, createdAt])
  @@index([deviceId, status])
  @@index([conversationId])
}

model CodeTaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  seq       Int
  kind      String
  payload   Json
  createdAt DateTime @default(now())

  task CodeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, seq])
}

// ----------------------------------------------------------------------------
// Public share links — read-only snapshots of a chat or artifact, addressable
// by an unguessable token. Snapshot semantics: the share page renders only
// messages/versions created at or before snapshotAt, so a link never leaks
// what the owner writes AFTER sharing. Revocation 404s the page immediately.
// ----------------------------------------------------------------------------

enum ShareKind {
  CHAT
  ARTIFACT
}

model Share {
  id             String    @id @default(cuid())
  token          String    @unique // long random URL slug (not the cuid)
  userId         String
  kind           ShareKind
  conversationId String?
  artifactId     String?
  title          String    @default("") // denormalized for lists + OG cards
  snapshotAt     DateTime  @default(now())
  views          Int       @default(0)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  artifact     Artifact?     @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([artifactId])
}

// ----------------------------------------------------------------------------
// Scheduled tasks — a prompt Juno runs on a recurrence, results appended to a
// dedicated conversation thread. Executed by the juno-scheduler pm2 worker
// (scripts/scheduled-task-runner.ts); spend is metered like any chat request.
// ----------------------------------------------------------------------------

enum TaskCadence {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

model ScheduledTask {
  id             String      @id @default(cuid())
  userId         String
  name           String
  prompt         String      @db.Text
  model          String // canonical "provider:model" id
  cadence        TaskCadence @default(DAILY)
  hour           Int         @default(8) // local to timezone
  minute         Int         @default(0)
  weekday        Int? // 0 (Sun) – 6 (Sat), WEEKLY only
  monthday       Int? // 1–28, MONTHLY only
  timezone       String      @default("Europe/Paris")
  webSearch      Boolean     @default(true)
  enabled        Boolean     @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime // recomputed by the runner after every run
  conversationId String? // results thread, created lazily on first run
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs ScheduledTaskRun[]

  @@index([enabled, nextRunAt])
  @@index([userId, createdAt])
}

model ScheduledTaskRun {
  id           String    @id @default(cuid())
  taskId       String
  status       String    @default("running") // running | done | error
  messageId    String? // assistant message holding the result
  error        String?
  costMicroUsd Int       @default(0)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?

  task ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
}

// ----------------------------------------------------------------------------
// Message versions — prior contents of a message preserved across regenerate /
// edit-and-resend, rendered as a carousel (never overwritten). content is
// encrypted at rest exactly like Message.content (same message-crypto path).
// ----------------------------------------------------------------------------

model MessageVersion {
  id               String   @id @default(cuid())
  messageId        String
  content          String   @db.Text
  reasoning        String?  @db.Text
  model            String?
  promptTokens     Int?
  completionTokens Int?
  sources          Json?
  createdAt        DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

// The Juno app's Code workspaces (project folders), mirrored so the website's
// Code tab can list the same Projects the app shows. The app owns the list and
// mirror-syncs it (PUT replaces the user's set).
model CodeWorkspace {
  id           String   @id
  userId       String
  name         String
  path         String
  // Stable workspace identity, minted by the client that owns the folder.
  // When present, mirror-sync matches on (userId, key) FIRST, so a moved
  // folder (new path) keeps the same server row — path is device metadata,
  // not identity. Nullable for rows synced by pre-key clients.
  // Uniqueness is enforced by a PARTIAL unique index (userId, key) WHERE key
  // IS NOT NULL — hand-written in migration 20260717130000 because Prisma
  // cannot express filtered indexes (and a schema-level @@unique would tempt
  // ON CONFLICT upserts that a partial index cannot arbitrate).
  key          String?
  lastOpenedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, path])
  @@index([userId, lastOpenedAt])
}
