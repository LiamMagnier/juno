# ==========================================================================
# Juno — environment variables
# Copy to `.env` for local dev and fill in. Add the same keys in the Vercel
# dashboard for production. Variables marked OPTIONAL can be left blank; the
# related feature degrades gracefully when they are absent.
# ==========================================================================

# --------------------------------------------------------------------------
# Core (REQUIRED)
# --------------------------------------------------------------------------

# PostgreSQL connection string.
# Neon:     https://neon.tech  -> Project -> Connection string (use the pooled
#           "-pooler" host for the app; see DIRECT_URL below for migrations).
# Supabase: https://supabase.com -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/juno?sslmode=require"

# OPTIONAL: a direct (non-pooled) connection used only for migrations.
# Required by Neon if DATABASE_URL points at the pooler. Leave blank otherwise.
DIRECT_URL=""

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Auth.js secret — generate with:  openssl rand -base64 32
AUTH_SECRET=""

# Public base URL of the app (no trailing slash).
# Local: http://localhost:3000   Production: https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OPTIONAL: comma-separated emails that get the "Owner" plan — unlimited messages,
# every model, no rate limits, 1 GB uploads. Match the email you sign in with.
OWNER_EMAILS=""

# --------------------------------------------------------------------------
# Additional model providers (OPTIONAL)
# Each provider's models appear in the model picker only when its key is set.
# ANTHROPIC_API_KEY (above) is required; these add GPT / Gemini / GLM / Kimi.
# All are OpenAI-compatible, so you may also override the base URL (e.g. regional
# endpoints, Azure, or a proxy) with the matching *_BASE_URL variable.
# --------------------------------------------------------------------------
# OpenAI (GPT) — https://platform.openai.com/api-keys  (also used by voice STT/TTS)
# OPENAI_API_KEY is declared in the Voice section below; one key serves both.
OPENAI_BASE_URL=""             # default https://api.openai.com/v1

# Google Gemini — https://aistudio.google.com/apikey
# NOTE: this is the Gemini API key, NOT the Google OAuth client below.
GOOGLE_API_KEY=""
GOOGLE_BASE_URL=""             # default https://generativelanguage.googleapis.com/v1beta/openai/

# Zhipu GLM — https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=""
ZHIPU_BASE_URL=""              # default https://open.bigmodel.cn/api/paas/v4  (intl: https://api.z.ai/api/paas/v4)

# Moonshot Kimi — https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=""
MOONSHOT_BASE_URL=""           # default https://api.moonshot.ai/v1

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL=""           # default https://api.deepseek.com

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=""
MISTRAL_BASE_URL=""            # default https://api.mistral.ai/v1

# xAI Grok — https://console.x.ai
XAI_API_KEY=""
XAI_BASE_URL=""                # default https://api.x.ai/v1

# --------------------------------------------------------------------------
# Image & video generation (OPTIONAL)
# Image/video models appear in the picker grouped by lab. They REUSE the keys
# above where the lab offers generation — no extra key needed:
#   • Image — GPT Image (OPENAI_API_KEY) · Nano Banana (GOOGLE_API_KEY) ·
#             Grok Image (XAI_API_KEY) · CogView (ZHIPU_API_KEY)
#   • Video — Veo 3 (GOOGLE_API_KEY) · CogVideoX (ZHIPU_API_KEY)
# The only new provider is ByteDance Seedance (cinematic text-to-video), served
# via Volcengine Ark. Add its key + region endpoint to enable Seedance models:
SEEDANCE_API_KEY=""            # Volcengine Ark API key — https://www.volcengine.com/docs/82379
SEEDANCE_BASE_URL=""           # default https://ark.cn-beijing.volces.com/api/v3

# --------------------------------------------------------------------------
# Web search with citations (OPTIONAL) — enables the "Search" toggle in chat
# (PRO+ plans). Uses Tavily (generous free tier). When set, capable chat models
# can fetch live sources and cite them; the message renders the source cards.
TAVILY_API_KEY=""              # https://app.tavily.com (free tier ~1k searches/mo)

# --------------------------------------------------------------------------
# Google OAuth (OPTIONAL — enables the "Continue with Google" button)
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# --------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --------------------------------------------------------------------------
# Storage — S3-compatible (REQUIRED for file/image uploads)
# Works with AWS S3, Cloudflare R2, Supabase Storage (S3), MinIO, etc.
# Supabase: Project Settings -> Storage -> S3 connection.
# --------------------------------------------------------------------------
S3_ENDPOINT=""                 # e.g. https://<project>.supabase.co/storage/v1/s3  (blank = AWS S3)
S3_REGION="us-east-1"
S3_BUCKET=""                   # bucket name, e.g. juno-uploads
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""               # OPTIONAL public base URL/CDN for objects; blank = use presigned GET URLs
S3_FORCE_PATH_STYLE="true"     # "true" for R2/Supabase/MinIO, "false" for AWS S3

# --------------------------------------------------------------------------
# Stripe billing (OPTIONAL — upgrade page & gating fall back to Free if absent)
# Keys:     https://dashboard.stripe.com/apikeys
# Prices:   create two recurring products (Pro, Max), copy each price id (price_...).
# Webhook:  https://dashboard.stripe.com/webhooks -> endpoint
#           {NEXT_PUBLIC_APP_URL}/api/stripe/webhook  (copy the signing secret)
# --------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""            # price id for the Pro plan
STRIPE_PRICE_MAX=""            # price id for the Max plan

# --------------------------------------------------------------------------
# Voice (OPTIONAL — without these, voice uses the browser Web Speech API only)
# STT_PROVIDER: "openai" or "deepgram"   TTS_PROVIDER: "openai" or "elevenlabs"
# --------------------------------------------------------------------------
STT_PROVIDER=""
TTS_PROVIDER=""
OPENAI_API_KEY=""              # used when STT_PROVIDER=openai (whisper) or TTS_PROVIDER=openai
DEEPGRAM_API_KEY=""            # used when STT_PROVIDER=deepgram
ELEVENLABS_API_KEY=""          # used when TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=""         # default ElevenLabs voice id
