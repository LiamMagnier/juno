# Core
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
ANTHROPIC_API_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Credential recovery email (required for “Forgot your password?”)
RESEND_API_KEY=""
EMAIL_FROM="Juno <hello@your-verified-domain.example>"

# Optional Google sign-in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional billing
STRIPE_SECRET_KEY=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_MAX=""
STRIPE_WEBHOOK_SECRET=""

# Optional S3-compatible uploads
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"
S3_PUBLIC_URL=""

# Universal managed app connectors (Composio).
# Without this the Connections page shows only Juno's built-in connectors; the
# Gmail/Slack/Linear/… directory stays empty. Free key: platform.composio.dev
COMPOSIO_API_KEY=""

# Deep research + web search (Tavily). REQUIRED for the composer's "Deep
# research" toggle to appear — it plans sub-questions, searches, and reads pages.
# Free tier is enough. Without it, Anthropic/Google/xAI models can still use
# their OWN native web search via the plain "Search" toggle.
TAVILY_API_KEY=""

# Voice. WITHOUT these two providers set, Juno silently falls back to the
# browser's Web Speech API — i.e. the macOS system voice, which reads French
# with an English accent and mis-transcribes non-English dictation.
STT_PROVIDER="openai"          # "openai" | "deepgram"
TTS_PROVIDER="openai"          # "openai" | "elevenlabs"
OPENAI_API_KEY=""              # also enables the GPT models + realtime voice relay
# Optional overrides (defaults shown):
# STT_MODEL="gpt-4o-transcribe"   # far better than whisper-1 on French
# TTS_MODEL="gpt-4o-mini-tts"     # reads each language with a native accent
# TTS_VOICE="alloy"
# DEEPGRAM_API_KEY=""
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""
