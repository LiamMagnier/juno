server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN; # Replace with api.yourdomain.com or your domain

    # Redirect all HTTP requests to HTTPS (Certbot will overwrite this, but it's a good default)
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN; # Replace with api.yourdomain.com or your domain

    # SSL configuration (to be populated by Let's Encrypt / Certbot automatically)
    # ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    # Logs
    access_log /var/log/nginx/juno_backend_access.log;
    error_log /var/log/nginx/juno_backend_error.log;

    # Announcement media uploads (images/videos) go through /api/admin/
    # announcements/upload with an app-level 100 MB cap — nginx's 1 MB default
    # client_max_body_size would 413 them before Next.js ever runs.
    client_max_body_size 120m;

    # Voice relay WebSocket (standalone service on :8787). Clients connect to
    # wss://YOUR_DOMAIN/voice-relay — the relay ignores the request path on
    # upgrade and serves /healthz at any path suffix, so the URI passes
    # through untouched (no proxy_pass URI part = no prefix rewriting).
    location /voice-relay {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Voice sessions are long-lived (up to 120 min per provider caps);
        # audio frames flow continuously, but keep a generous idle ceiling.
        proxy_buffering off;
        proxy_read_timeout 7200s;
        proxy_send_timeout 7200s;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        
        # Headers for WebSockets and streaming
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;

        # Large uploads stream straight to Next instead of buffering to
        # nginx temp files first.
        proxy_request_buffering off;

        # Streaming settings for LLM reasoning responses (Server-Sent Events).
        # proxy_read_timeout is the ceiling between reads from the app; on a
        # self-hosted box THIS replaces Vercel's 300s maxDuration wall. The chat
        # route sends a ping every 15s (see route.ts heartbeat), which resets this
        # timer, so the connection survives long silent "thinking" gaps regardless.
        # 3600s (1h) is a generous safety margin for max-effort reasoning runs.
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        chunked_transfer_encoding on;
    }
}
